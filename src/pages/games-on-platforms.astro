---
// CS340 Portfolio Project - Group 101
// Cameron Brooks & Brayden Plumb
// Games on Platforms page: Browse, Add, Update, Delete game-platform associations (M:N intersection table)
// UPDATE M:N relationship implemented here — user can change gameID or platformID on an existing association.
//
// Citation (accessed Jan-Mar 2026): CRUD pattern adapted from Astro SSR docs
// (https://docs.astro.build/en/guides/on-demand-rendering/). mysql2/promise for DB calls.
// AI tools (Claude) assisted with initial scaffolding. SP wiring by Brayden Plumb.
// UPDATE M:N is our own original work.

import Layout from '../layouts/Layout.astro';
import { getConnection } from '../lib/db';

let associations: any[] = [];
let games: any[] = [];
let platforms: any[] = [];
let error = '';
let message = '';

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const action = form.get('action');
    const db = await getConnection();

    if (action === 'insert') {
      const gameID = form.get('gameID');
      const platformID = form.get('platformID');
      await db.query('CALL sp_insert_game_on_platform(?, ?)', [gameID, platformID]);
      message = 'Game-platform association added.';
    } else if (action === 'update') {
      const gameOnPlatformID = form.get('gameOnPlatformID');
      const gameID = form.get('gameID');
      const platformID = form.get('platformID');
      await db.query('CALL sp_update_game_on_platform(?, ?, ?)', [gameOnPlatformID, gameID, platformID]);
      message = `Association ${gameOnPlatformID} updated.`;
    } else if (action === 'delete') {
      const gameOnPlatformID = form.get('gameOnPlatformID');
      await db.query('CALL sp_delete_game_on_platform(?)', [gameOnPlatformID]);
      message = `Association ${gameOnPlatformID} removed.`;
    }

    await db.end();
  } catch (e: any) {
    error = e.message;
  }
}

try {
  const db = await getConnection();

  const [[assocRows]] = await db.query<any[]>('CALL sp_select_all_games_on_platforms()');
  associations = assocRows;

  const [[gameRows]] = await db.query<any[]>('CALL sp_select_all_games()');
  games = gameRows;

  const [[platRows]] = await db.query<any[]>('CALL sp_select_all_platforms()');
  platforms = platRows;

  await db.end();
} catch (e: any) {
  error = e.message;
}
---

<Layout title="Games on Platforms">
  <h1 class="page-title">Games on Platforms</h1>

  {message && <p style="color: green; font-weight: bold;">{message}</p>}
  {error && <p style="color: red;">Database error: {error}</p>}

  <!-- Browse All Associations -->
  <div class="section-card">
    <h2>Browse All Game-Platform Associations</h2>
    <p>This M:N intersection table tracks which games are available on which platforms. One game can be on many platforms, and one platform can host many games.</p>
    <table>
      <thead>
        <tr>
          <th>Association ID</th>
          <th>Game</th>
          <th>Platform</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {associations.length === 0 && (
          <tr><td colspan="4" style="text-align:center; color:#9ca3af;">No associations found.</td></tr>
        )}
        {associations.map((assoc) => (
          <tr>
            <td>{assoc.gameOnPlatformID}</td>
            <td>{assoc.gameTitle}</td>
            <td>{assoc.platformName}</td>
            <td>
              <div class="actions">
                <button class="btn btn-warning btn-sm" onclick={`document.getElementById('edit-id').value='${assoc.gameOnPlatformID}'; document.getElementById('edit-gameID').value='${assoc.gameID}'; document.getElementById('edit-platformID').value='${assoc.platformID}'; document.getElementById('edit-section').scrollIntoView({behavior:'smooth'})`}>Edit</button>
                <form method="POST" action="/games-on-platforms" style="display:inline;">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="gameOnPlatformID" value={assoc.gameOnPlatformID} />
                  <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Add New Association -->
  <div class="section-card">
    <h2>Add Game to Platform</h2>
    <p>Associate a game with a platform to indicate it can be played on that platform.</p>
    <form method="POST" action="/games-on-platforms">
      <input type="hidden" name="action" value="insert" />
      <div class="form-grid">
        <div class="form-group">
          <label for="add-gameID">Game *</label>
          <select id="add-gameID" name="gameID" required>
            <option value="">-- Select a Game --</option>
            {games.map((game) => (
              <option value={game.gameID}>{game.title}</option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label for="add-platformID">Platform *</label>
          <select id="add-platformID" name="platformID" required>
            <option value="">-- Select a Platform --</option>
            {platforms.map((p) => (
              <option value={p.platformID}>{p.name}</option>
            ))}
          </select>
        </div>
      </div>
      <button type="submit" class="btn btn-primary">Add Association</button>
    </form>
  </div>

  <!-- Update Existing Association (M:N UPDATE) -->
  <div class="section-card" id="edit-section">
    <h2>Update Game-Platform Association</h2>
    <p>Select an association from the table above by clicking "Edit", then change the game or platform below.</p>
    <form method="POST" action="/games-on-platforms">
      <input type="hidden" name="action" value="update" />
      <div class="form-grid">
        <div class="form-group">
          <label for="edit-id">Association ID</label>
          <input type="number" id="edit-id" name="gameOnPlatformID" required readonly placeholder="Click Edit on a row above" />
          <span class="hint">Auto-filled when clicking Edit</span>
        </div>
        <div class="form-group">
          <label for="edit-gameID">Game *</label>
          <select id="edit-gameID" name="gameID" required>
            <option value="">-- Select a Game --</option>
            {games.map((game) => (
              <option value={game.gameID}>{game.title}</option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label for="edit-platformID">Platform *</label>
          <select id="edit-platformID" name="platformID" required>
            <option value="">-- Select a Platform --</option>
            {platforms.map((p) => (
              <option value={p.platformID}>{p.name}</option>
            ))}
          </select>
        </div>
      </div>
      <button type="submit" class="btn btn-warning">Update Association</button>
    </form>
  </div>
</Layout>
