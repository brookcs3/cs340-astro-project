  }

  .section-card ul {
    margin: 0.5rem 0 0 1.5rem;
    line-height: 1.8;
  }

  .section-card li {
    font-size: 0.9rem;
  }

  .section-card p {
    font-size: 0.9rem;
    color: #374151;
  }
</style>
